@{
}
@model List<HospitalManagement.Models.DoctorModel>;
<html>

    <head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    </head>
    <body>
<a href="Add"><i class="fa-solid fa-plus"></i> Add New Doctor</a>
<table id="example" class="table table-striped">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Gender Name</th>
                <th>Join Date</th>
                <th>Salary</th>
                <th>Mobile</th>
                <th>Shift Name</th>
                <th>Specialization Name</th>
                <th>Year Of Experience</th>
                <th>Action</th>

        </tr>
    </thead>
    <tbody>
            @foreach (HospitalManagement.Models.DoctorModel item in Model)
        {
            <tr>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.GenderName</td>
                <td>@item.JoinDate</td>
                <td>@item.Salary</td>
                    <td>@item.Mobile</td>
                     <td>@item.ShiftName</td>
                    <td>@item.SpecializationName</td>
                    <td>@item.YearOfExperience</td>
                <td><a asp-controller="Doctor" asp-action="Edit" asp-route-Id="@item.DoctoeId"><i class="fa-solid fa-pencil"></i></a></td>
                <td><a asp-controller="Doctor" asp-action="Delete" asp-route-Id="@item.DoctoeId"><i class="fa-solid fa-trash"></i></a> </td>
                @*   @if (item.Gender==true)
                    {
                        <td>Male</td>
                    }
                    else
                    {
                        <td>Female</td>
                    }
                    *@
            </tr>
        }
    </tbody>

</table>
</body>
</html>